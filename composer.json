{
    "name": "leblanc-simon/openerpbyjsonrpc",
    "description": "Library to communicate into PHP and OpenERP (Odoo)",
    "license": "MIT",
    "keywords": ["odoo", "openerp", "jsonrpc"],

    "type": "library",

    "authors": [
        {
            "name": "Simon Leblanc",
            "email": "contact@leblanc-simon.eu"
        }
    ],

    "autoload": {
        "psr-4": {
            "OpenErpByJsonRpc\\": "src/"
        }
    },

    "require": {
        "php": ">= 8.1",
        "ext-json": "*",
        "laminas/laminas-json": "^3.6",
        "laminas/laminas-server": "^2.17",
        "laminas/laminas-http": "^2.19",
        "laminas/laminas-json-server": "^3.9"
    },

    "require-dev": {
        "phpunit/phpunit": "~9.5",
        "phpstan/phpstan": "^1.11"
    }
}
