{
    "name": "leblanc-simon/openerpbyjsonrpc",
    "description": "Library to communicate into PHP and OpenERP (Odoo)",
    "license": "MIT",
    "keywords": ["odoo", "openerp", "jsonrpc"],

    "type": "library",

    "authors": [
        {
            "name": "Simon Leblanc",
            "email": "contact@leblanc-simon.eu"
        }
    ],

    "autoload": {
        "psr-4": {
            "OpenErpByJsonRpc\\": "src/"
        }
    },

    "autoload-dev": {
        "psr-4": {
            "OpenErpByJsonRpc\\Rector\\": "utils/rector/"
        }
    },

    "require": {
        "php": ">= 8.5",
        "ext-json": "*",
        "laminas/laminas-json-server": ">= 3.10"
    },

    "require-dev": {
        "phpunit/phpunit": "~13.2.0",
        "phpstan/phpstan": "^2.2.2",
        "rector/rector": "^2.4"
    },

    "scripts": {
        "cs-check": "tools/php-cs-fixer/vendor/bin/php-cs-fixer fix --dry-run --diff",
        "cs-fix": "tools/php-cs-fixer/vendor/bin/php-cs-fixer fix"
    }
}
